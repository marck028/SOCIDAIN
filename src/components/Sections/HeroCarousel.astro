---
import Button from "../UI/Button.astro";

export interface Props {
    title?: string;
    subtitle?: string;
    images: string[];
    ctaText?: string;
    ctaLink?: string;
    secondaryCtaText?: string;
    secondaryCtaLink?: string;
}

const {
    title = "SOCIDAIN",
    subtitle = "Sociedad Científica de Ciencia de Datos e Inteligencia de Negocios",
    images = [],
    ctaText = "Conócenos",
    ctaLink = "/about-us",
    secondaryCtaText = "Proyectos",
    secondaryCtaLink = "/ministries",
} = Astro.props;
---

<section
    class="relative h-[100vh] lg:h-screen w-full flex items-center overflow-hidden bg-gray-900 group"
>
    <!-- Carousel Background -->
    <div id="hero-carousel" class="absolute inset-0 z-0">
        {
            images.map((img, index) => (
                <div
                    class={`carousel-slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? "opacity-100" : "opacity-0"}`}
                    data-index={index}
                >
                    <div class="absolute inset-0 bg-black/40 z-10" />
                    <img
                        src={img}
                        alt={`Slide ${index + 1}`}
                        class="w-full h-full object-cover object-center"
                    />
                </div>
            ))
        }
    </div>

    <!-- Content -->
    <div class="container relative z-20 px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl text-white">
            <h1
                class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold mb-6 text-white leading-tight animate-fade-in-up drop-shadow-lg"
            >
                {title}
            </h1>
            <p
                class="text-lg sm:text-xl md:text-2xl lg:text-3xl mb-10 text-gray-100 animate-fade-in-up delay-100 max-w-2xl drop-shadow-md"
            >
                {subtitle}
            </p>

            <div
                class="flex flex-col sm:flex-row flex-wrap gap-4 animate-fade-in-up delay-200"
            >
                <Button
                    href={ctaLink}
                    variant="primary"
                    size="lg"
                    class="w-full sm:w-auto text-center"
                >
                    {ctaText}
                </Button>

                <Button
                    href={secondaryCtaLink}
                    variant="outline"
                    size="lg"
                    class="w-full sm:w-auto text-center bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm transition-all duration-300"
                >
                    {secondaryCtaText}
                </Button>
            </div>
        </div>
    </div>

    <!-- Indicators -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-30">
        {
            images.map((_, index) => (
                <button
                    class={`carousel-indicator w-3 h-3 rounded-full border-2 border-white transition-all duration-300 ${index === 0 ? "bg-white w-8" : "bg-transparent"}`}
                    data-index={index}
                    aria-label={`Go to slide ${index + 1}`}
                />
            ))
        }
    </div>

    <!-- Progress Bar (Optional Visual Touch) -->
    <div
        class="absolute bottom-0 left-0 h-1 bg-primary-600/50 z-40 w-0"
        id="carousel-progress"
    >
    </div>
</section>

<style>
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    .delay-100 {
        animation-delay: 0.1s;
    }
    .delay-200 {
        animation-delay: 0.2s;
    }

    /* Smooth Slide Transitions */
    .carousel-slide {
        pointer-events: none;
    }
    .carousel-slide.opacity-100 {
        pointer-events: auto;
    }
</style>

<script>
    function initCarousel() {
        const slides = document.querySelectorAll(".carousel-slide");
        const indicators = document.querySelectorAll(".carousel-indicator");
        const progressBar = document.getElementById("carousel-progress");

        if (slides.length <= 1) return;

        let currentIndex = 0;
        const intervalTime = 6000; // 6 seconds per slide
        let carouselInterval: any;

        function showSlide(index: number) {
            // Remove active classes
            slides[currentIndex].classList.remove("opacity-100");
            slides[currentIndex].classList.add("opacity-0");
            indicators[currentIndex].classList.remove("bg-white", "w-8");
            indicators[currentIndex].classList.add("bg-transparent");

            // Add active classes to new slide
            currentIndex = index;
            slides[currentIndex].classList.remove("opacity-0");
            slides[currentIndex].classList.add("opacity-100");
            indicators[currentIndex].classList.add("bg-white", "w-8");
            indicators[currentIndex].classList.remove("bg-transparent");

            // Reset progress bar animation
            if (progressBar) {
                progressBar.style.transition = "none";
                progressBar.style.width = "0";
                setTimeout(() => {
                    progressBar.style.transition = `width ${intervalTime}ms linear`;
                    progressBar.style.width = "100%";
                }, 50);
            }
        }

        function nextSlide() {
            let next = (currentIndex + 1) % slides.length;
            showSlide(next);
        }

        function startInterval() {
            carouselInterval = setInterval(nextSlide, intervalTime);
            if (progressBar) {
                progressBar.style.transition = `width ${intervalTime}ms linear`;
                progressBar.style.width = "100%";
            }
        }

        function stopInterval() {
            clearInterval(carouselInterval);
        }

        // Set up indicator clicks
        indicators.forEach((indicator, i) => {
            indicator.addEventListener("click", () => {
                stopInterval();
                showSlide(i);
                startInterval();
            });
        });

        // Start the carousel
        startInterval();
    }

    // Initialize on page load and swaps
    document.addEventListener("astro:page-load", initCarousel);
    // Fallback for initial load if view transitions aren't used or for first load
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCarousel);
    } else {
        initCarousel();
    }
</script>
