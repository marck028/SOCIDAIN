---
export interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string | null;
}

const { title, subtitle, backgroundImage = null } = Astro.props;
---

<section
  class={`relative py-12 ${!backgroundImage ? "bg-[#555555]" : "bg-cover bg-center"}`}
  style={backgroundImage
    ? `background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(${backgroundImage})`
    : ""}
>
  <div class="container">
    <div class="max-w-4xl mx-auto text-center text-white">
      <h1 class="text-4xl md:text-6xl font-bold mb-4 text-white font-serif">
        {title}
      </h1>
      {
        subtitle && (
          <p class="text-xl md:text-2xl font-sans opacity-90">{subtitle}</p>
        )
      }
    </div>
  </div>
</section>
