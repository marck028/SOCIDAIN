---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import StaffList from "../components/Sections/StaffList.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout
  title="Directiva - SOCIDAIN"
  description="Conoce al equipo de liderazgo y académicos que impulsan la ciencia de datos en SOCIDAIN."
>
  <PageHeader
    title="Directiva"
    subtitle="Conoce a las personas que lideran SOCIDAIN"
  />

  <!-- Staff List -->
  <StaffList />

  <!-- Contact Staff CTA -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
          ¿Necesitas contactar a nuestra directiva?
        </h2>
        <p class="text-xl text-gray-600 mb-8">
          Nuestros coordinadores están a tu disposición para proyectos
          complejos, investigación conjunta o tutorías académicas. No dudes en
          comunicarte directamente con nosotros para cualquier colaboración.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/contact" variant="primary"> Contáctanos </Button>

          <Button href="/about-us" variant="outline">
            Saber más sobre SOCIDAIN
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
