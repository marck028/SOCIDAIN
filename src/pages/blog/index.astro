---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import Card from "../../components/UI/Card.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/dateUtils";
import Button from "../../components/UI/Button.astro";

// Get all blog posts
const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort by date (newest first)
const posts = allPosts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);

const categories = [
  "Todos",
  "Proyectos de Software",
  "Investigación Científica",
  "Tutoriales & Análisis",
];

const getCategoryCount = (cat: string) => {
  if (cat === "Todos") return posts.length;
  return posts.filter(post => post.data.category === cat).length;
};
---

<BaseLayout
  title="Portafolio - SOCIDAIN"
  description="Explora los últimos artículos, investigaciones y tutoriales de nuestra comunidad de ciencia de datos."
>
  <PageHeader
    title="Portafolio de Trabajos"
    subtitle="Perspectivas, investigaciones y tutoriales de nuestra comunidad científica"
    backgroundImage={null}
  />

  <!-- Blog Posts List -->
  <section class="py-16">
    <div class="container">
      {
        posts.length > 0 ? (
          <>
            <!-- Category Filters -->
            <div class="flex flex-wrap gap-4 mb-10" id="category-filters">
              {categories.map((cat) => {
                const count = getCategoryCount(cat);
                const isActive = cat === "Todos";
                const baseClasses = "px-6 py-2 rounded-full text-sm font-bold transition-all cursor-pointer filter-pill border-2";
                const activeClasses = "bg-[#900033] border-[#900033] text-white";
                const inactiveClasses = "bg-transparent border-[#900033] text-[#900033] hover:bg-[#900033] hover:text-white";
                
                return (
                  <button
                    class={`${baseClasses} ${isActive ? activeClasses : inactiveClasses}`}
                    data-category={cat}
                    data-active-class={activeClasses}
                    data-inactive-class={inactiveClasses}
                  >
                    {cat} ({count})
                  </button>
                )
              })}
            </div>

            <!-- Posts Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
              {posts.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="group bg-white rounded-3xl shadow-sm border border-gray-100 hover:shadow-2xl transition-all duration-500 flex flex-col h-full overflow-hidden relative post-card"
                  data-category={post.data.category || ""}
                >
                  <!-- Cover image area -->
                  {post.data.coverImage ? (
                    <div class="w-full aspect-video overflow-hidden shrink-0">
                      <img 
                        src={post.data.coverImage} 
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      />
                    </div>
                  ) : (
                    <div class="w-full aspect-video bg-[#900033] shrink-0 flex items-center justify-center p-6 text-center">
                      <span class="text-white font-bold text-xl">{post.data.category || "SOCIDAIN"}</span>
                    </div>
                  )}

                  <div class="p-8 flex flex-col flex-grow">
                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-[#900033] transition-colors line-clamp-2 leading-tight mb-4">
                      {post.data.title}
                    </h3>

                    <!-- Metadata -->
                    <div class="flex flex-wrap gap-4 mb-4 text-xs font-bold uppercase tracking-widest text-gray-400">
                      <div class="flex items-center">
                        {formatDate(post.data.pubDate)}
                      </div>
                      <div class="flex items-center">
                        {post.data.author}
                      </div>
                    </div>

                    <p class="text-gray-600 mb-6 line-clamp-3 text-sm leading-relaxed">
                      {post.data.description}
                    </p>

                    <div class="mt-auto pt-6 border-t border-gray-50 flex items-center text-[#900033] font-bold text-sm tracking-wide group-hover:gap-2 transition-all">
                      <span>LEER TRABAJO</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>

            <!-- Empty State (hidden by default) -->
            <div id="empty-state" class="hidden h-full">
              <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 flex flex-col items-center justify-center min-h-[300px] text-center w-full max-w-sm mx-auto">
                <h3 class="text-lg font-bold text-gray-900 leading-tight">
                  Próximamente trabajos en esta categoría
                </h3>
              </div>
            </div>
          </>
        ) : (
          <div class="text-center py-20 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
            <h3 class="text-2xl font-bold text-gray-800 mb-2">
              Aún no se publicaron trabajos
            </h3>
            <p class="text-gray-600 max-w-md mx-auto">
              Estamos preparando contenido increíble para ti. ¡Vuelve pronto o
              sé el primero en publicar!
            </p>
          </div>
        )
      }
    </div>
  </section>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const filters = document.querySelectorAll(".filter-pill");
      const postCards = document.querySelectorAll(".post-card");
      const emptyState = document.getElementById("empty-state");
      const postsGrid = document.getElementById("posts-grid");

      if (!filters.length || !postsGrid || !emptyState) return;

      filters.forEach((filter) => {
        filter.addEventListener("click", () => {
          const selectedCategory = filter.getAttribute("data-category");
          
          // Update active filter styling
          filters.forEach((f) => {
            const activeClass = f.getAttribute("data-active-class") || "";
            const inactiveClass = f.getAttribute("data-inactive-class") || "";
            
            if (f === filter) {
              f.className = f.className.replace(inactiveClass, "").trim() + " " + activeClass;
            } else {
              // Ensure we're clearing up multiple spaces when replacing
              f.className = f.className.replace(activeClass, "").trim() + " " + inactiveClass;
              // cleanup multiple spaces
              f.className = f.className.replace(/\s+/g, ' ');
            }
          });

          // Filter posts
          let visibleCount = 0;
          postCards.forEach((card) => {
            const el = card as HTMLElement;
            const postCategory = el.getAttribute("data-category");
            if (selectedCategory === "Todos" || postCategory === selectedCategory) {
              el.style.display = "flex";
              visibleCount++;
            } else {
              el.style.display = "none";
            }
          });

          // Handle empty state
          if (visibleCount === 0) {
            postsGrid.style.display = "none";
            emptyState.style.display = "flex";
          } else {
            postsGrid.style.display = "grid";
            emptyState.style.display = "none";
          }
        });
      });
    });
  </script>

  <!-- Student Contribution CTA -->
  <section class="py-20 bg-gray-50">
    <div class="container text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        ¿Te gustaría publicar tu trabajo?
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Invitamos a todos los estudiantes e investigadores de Univalle a
        compartir sus hallazgos, tutoriales o análisis con nuestra comunidad
        científica.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <Button
          href="https://wa.me/59165730807?text=Hola%20SOCIDAIN!%20Me%20gustaría%20publicar%20mi%20trabajo%20en%20el%20portafolio."
          target="_blank"
          variant="primary"
        >
          Subir mi Trabajo
        </Button>
        <Button href="/contact" variant="outline"> Más Información </Button>
      </div>
    </div>
  </section>
</BaseLayout>
