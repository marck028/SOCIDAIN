---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/dateUtils";

// Generate static paths for all blog posts
export async function getStaticPaths() {
  try {
    const blogEntries = await getCollection("blog", ({ data }) => {
      return import.meta.env.PROD ? !data.draft : true;
    });

    return blogEntries.map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
  } catch (error) {
    // If the collection doesn't exist yet, return an empty array
    return [];
  }
}

// Get the blog post data
const { entry } = Astro.props;
const { Content } = await entry.render();

// Calculate estimated reading time
const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Find related posts (posts with matching tags)
let relatedPosts: any[] = [];
try {
  const allPosts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  // Find posts that share at least one tag with the current post
  const postTags = entry.data.tags || [];

  if (postTags.length > 0) {
    relatedPosts = allPosts
      .filter(
        (post) =>
          post.slug !== entry.slug && // Not the current post
          post.data.tags.some((tag) => postTags.includes(tag)), // Has at least one matching tag
      )
      .sort((a, b) => {
        // Sort by number of matching tags (descending)
        const aMatchCount = a.data.tags.filter((tag) =>
          postTags.includes(tag),
        ).length;
        const bMatchCount = b.data.tags.filter((tag) =>
          postTags.includes(tag),
        ).length;
        return bMatchCount - aMatchCount;
      })
      .slice(0, 3);
  }
} catch (error) {
  console.log("Error fetching related posts");
}
---

<BaseLayout
  title={`${entry.data.title} - Blog SOCIDAIN`}
  description={entry.data.description}
  type="article"
>
  <!-- Medium Style Header -->
  {entry.data.coverImage ? (
    <div class="relative w-full max-h-[420px] overflow-hidden bg-black flex items-center justify-center">
      <img 
        src={entry.data.coverImage} 
        alt={entry.data.title} 
        class="absolute inset-0 w-full h-full object-cover opacity-50"
      />
      <div class="relative z-10 container mx-auto px-4 py-24 md:py-32 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl mx-auto drop-shadow-md">
          {entry.data.title}
        </h1>
        
        <div class="flex flex-wrap justify-center items-center gap-4 text-white">
          {entry.data.category && (
            <span class="px-4 py-1.5 border-2 border-[#900033] text-white font-bold rounded-full text-sm">
              {entry.data.category}
            </span>
          )}
          <span class="text-sm font-medium opacity-90">{formatDate(entry.data.pubDate)}</span>
          <span class="text-sm font-medium opacity-90">•</span>
          <span class="text-sm font-medium opacity-90">{readingTime} min de lectura</span>
        </div>
      </div>
    </div>
  ) : (
    <div class="container mx-auto px-4 pt-24 pb-12 text-center max-w-4xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
        {entry.data.title}
      </h1>
      
      <div class="flex flex-wrap justify-center items-center gap-4">
        {entry.data.category && (
          <span class="px-4 py-1.5 border-2 border-[#900033] text-[#900033] font-bold rounded-full text-sm">
            {entry.data.category}
          </span>
        )}
        <span class="text-sm font-medium text-gray-500">{formatDate(entry.data.pubDate)}</span>
        <span class="text-sm font-medium text-gray-400">•</span>
        <span class="text-sm font-medium text-gray-500">{readingTime} min de lectura</span>
      </div>
    </div>
  )}

  <main class="container py-8">
    <div class="mx-auto max-w-2xl">
      <!-- Author Profile Card -->
      {
        entry.data.image && (
          <div class="flex items-center gap-4 mb-10 p-5 bg-gray-50 rounded-2xl border border-gray-100">
            <img
              src={entry.data.image.url}
              alt={entry.data.image.alt}
              class="w-16 h-16 rounded-full object-cover object-top border-4 border-black flex-shrink-0 shadow-md"
            />
            <div>
              <p class="font-bold text-gray-900 text-lg">{entry.data.author}</p>
              <p class="text-sm text-gray-500">Autor • SOCIDAIN</p>
            </div>
          </div>
        )
      }

      <!-- Blog Post Content -->
      <article
        class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl prose-h4:text-lg prose-p:text-gray-700 prose-p:leading-loose prose-li:text-gray-700 prose-li:leading-loose prose-strong:text-gray-900 prose-a:text-[#900033] hover:prose-a:text-red-900"
      >
        <Content />
      </article>

      <!-- Share Option -->
      <div class="mt-16 py-6 border-t border-gray-200">
        <h3 class="text-lg font-bold mb-4 text-gray-900">
          Compartir esta Publicación
        </h3>
        <button
          id="copy-link-btn"
          class="inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 px-5 py-2.5 rounded-xl font-bold text-sm transition-all active:scale-95 group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-gray-500 group-hover:text-[#900033] transition-colors"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"
            ></path>
          </svg>
          <span id="copy-text">Copiar Link</span>
        </button>
      </div>

      <script>
        const copyBtn = document.getElementById("copy-link-btn");
        const copyText = document.getElementById("copy-text");

        if (copyBtn && copyText) {
          copyBtn.addEventListener("click", async () => {
            try {
              await navigator.clipboard.writeText(window.location.href);

              // Visual feedback
              const originalText = copyText.innerText;
              copyText.innerText = "¡Copiado!";
              copyBtn.classList.remove("bg-gray-100");
              copyBtn.classList.add(
                "bg-red-50",
                "text-[#900033]",
                "border",
                "border-red-100",
              );

              setTimeout(() => {
                copyText.innerText = originalText;
                copyBtn.classList.add("bg-gray-100");
                copyBtn.classList.remove(
                  "bg-red-50",
                  "text-[#900033]",
                  "border",
                  "border-red-100",
                );
              }, 2000);
            } catch (err) {
              console.error("Error al copiar:", err);
            }
          });
        }
      </script>

      <!-- Related Posts -->
      {
        relatedPosts.length > 0 && (
          <div class="mt-12">
            <h2 class="text-2xl font-bold mb-6">Publicaciones Relacionadas</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {relatedPosts.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="block bg-gray-50 rounded-lg p-4 hover:bg-gray-100 transition-colors"
                >
                  <h3 class="font-bold mb-2 line-clamp-2">{post.data.title}</h3>
                  <p class="text-sm text-gray-600 mb-2">Por {post.data.author}</p>
                  <p class="text-[#900033] text-sm font-medium">Leer Más →</p>
                </a>
              ))}
            </div>
          </div>
        )
      }

      <!-- Navigation -->
      <div class="mt-12">
        <a
          href="/blog"
          class="inline-flex items-center text-[#900033] hover:text-red-900"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 mr-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Volver a Todas las Publicaciones
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
